// Sanflait — Schema Prisma
// Banco PostgreSQL · Multi-loja · CRM · Tracking · BI

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  GERENTE
  VENDEDOR
  SUPORTE
}

enum Gender {
  MASCULINO
  FEMININO
  OUTRO
}

enum CrmStatus {
  LEAD
  EM_NEGOCIACAO
  CONVERTIDO
  PERDIDO
}

enum SaleStatus {
  CONVERTIDO
  EM_NEGOCIACAO
  PERDIDO
  CANCELADO
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  ORGANICO
  LINK_VENDEDOR
  INDICACAO
  LOJA_FISICA
  OUTROS
}

enum EventType {
  PAGE_VIEW
  PRODUCT_VIEW
  ADD_TO_WISHLIST
  WHATSAPP_CLICK
  CONTACT_FORM
  PURCHASE
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(VENDEDOR)
  initials     String?
  avatarColor  String?
  active       Boolean    @default(true)

  storeId      String?
  store        Store?     @relation(fields: [storeId], references: [id])

  vendor       Vendor?
  refreshTokens RefreshToken[]
  crmLogs      CrmLog[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ============================================
// VENDORS
// ============================================

model Vendor {
  id           String     @id @default(uuid())
  slug         String     @unique
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id])
  phone        String
  bio          String?

  customers    Customer[]
  sales        Sale[]
  trackingSessions TrafficSession[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([slug])
  @@index([storeId])
}

// ============================================
// STORES
// ============================================

model Store {
  id           String     @id @default(uuid())
  name         String
  address      String
  city         String
  hours        String?
  mapsUrl      String?
  wazeUrl      String?
  description  String?
  active       Boolean    @default(true)

  users        User[]
  vendors      Vendor[]
  inventories  Inventory[]
  sales        Sale[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id           String     @id @default(uuid())
  name         String
  email        String?
  phone        String
  neighborhood String?
  city         String?
  age          Int?
  gender       Gender?
  status       CrmStatus  @default(LEAD)
  source       String?
  notes        String?

  vendorId     String?
  vendor       Vendor?    @relation(fields: [vendorId], references: [id])

  sales        Sale[]
  crmLogs      CrmLog[]
  trafficSessions TrafficSession[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([vendorId])
  @@index([neighborhood])
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id           String     @id @default(uuid())
  slug         String     @unique
  name         String
  category     String
  collection   String?
  description  String?
  basePrice    Decimal    @db.Decimal(12, 2)
  oldPrice     Decimal?   @db.Decimal(12, 2)
  badge        String?
  active       Boolean    @default(true)
  images       String[]   @default([])

  variants     ProductVariant[]
  priceHistory ProductPriceHistory[]
  saleItems    SaleItem[]
  trafficEvents TrafficEvent[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([slug])
  @@index([category])
  @@index([collection])
}

model ProductVariant {
  id           String     @id @default(uuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String     @unique
  color        String
  size         String
  price        Decimal?   @db.Decimal(12, 2)

  inventories  Inventory[]
  saleItems    SaleItem[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([productId])
  @@index([sku])
}

model ProductPriceHistory {
  id           String     @id @default(uuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldPrice     Decimal    @db.Decimal(12, 2)
  newPrice     Decimal    @db.Decimal(12, 2)
  changedBy    String?
  reason       String?
  createdAt    DateTime   @default(now())

  @@index([productId])
}

// ============================================
// INVENTORY (multi-loja × variante)
// ============================================

model Inventory {
  id           String     @id @default(uuid())
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity     Int        @default(0)
  reserved     Int        @default(0)
  minStock     Int        @default(2)

  updatedAt    DateTime   @updatedAt

  @@unique([storeId, variantId])
  @@index([storeId])
  @@index([variantId])
}

// ============================================
// SALES
// ============================================

model Sale {
  id           String     @id @default(uuid())
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  vendorId     String
  vendor       Vendor     @relation(fields: [vendorId], references: [id])
  storeId      String?
  store        Store?     @relation(fields: [storeId], references: [id])

  amount       Decimal    @db.Decimal(12, 2)
  description  String?
  channel      Channel    @default(LOJA_FISICA)
  status       SaleStatus @default(CONVERTIDO)

  attributedSessionId String?
  attributedSession   TrafficSession? @relation(fields: [attributedSessionId], references: [id])

  items        SaleItem[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id           String     @id @default(uuid())
  saleId       String
  sale         Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  quantity     Int        @default(1)
  unitPrice    Decimal    @db.Decimal(12, 2)

  @@index([saleId])
}

// ============================================
// TRACKING & ATTRIBUTION
// ============================================

model TrafficSession {
  id           String     @id @default(uuid())
  sessionToken String     @unique
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  vendorId     String?
  vendor       Vendor?    @relation(fields: [vendorId], references: [id])

  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  referrer     String?
  landingPage  String?
  userAgent    String?
  ipHash       String?

  firstSeenAt  DateTime   @default(now())
  lastSeenAt   DateTime   @default(now())

  events       TrafficEvent[]
  sales        Sale[]

  @@index([sessionToken])
  @@index([vendorId])
  @@index([customerId])
}

model TrafficEvent {
  id           String     @id @default(uuid())
  sessionId    String
  session      TrafficSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type         EventType
  productId    String?
  product      Product?   @relation(fields: [productId], references: [id])
  metadata     Json?
  createdAt    DateTime   @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// CRM
// ============================================

model CrmLog {
  id           String     @id @default(uuid())
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  action       String     // CONTACT, NOTE, STATUS_CHANGE, FOLLOW_UP, etc.
  description  String?
  oldStatus    CrmStatus?
  newStatus    CrmStatus?

  createdAt    DateTime   @default(now())

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// CAMPAIGNS (gestão de UTMs e campanhas)
// ============================================

model Campaign {
  id           String     @id @default(uuid())
  name         String
  source       String     // ex: instagram, meta_ads
  medium       String?    // ex: cpc, organic, email
  campaign     String     // identificador da campanha
  budget       Decimal?   @db.Decimal(12, 2)
  startDate    DateTime?
  endDate      DateTime?
  active       Boolean    @default(true)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([source, campaign])
  @@index([active])
}
