# PostgreSQL (Supabase)
# Formato: postgresql://postgres:[SENHA]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sanflait?schema=public"

# Redis (BullMQ) — opcional em produção
REDIS_URL="redis://localhost:6379"

# JWT — gere com: openssl rand -base64 64
JWT_SECRET="change-me-in-production-this-needs-to-be-very-long-and-random"
JWT_REFRESH_SECRET="another-very-long-secret-for-refresh-tokens"

# Server
PORT=3333
NODE_ENV=development

# CORS — URL do frontend em produção
CORS_ORIGIN="http://localhost:5173"

# Storage (Supabase)
SUPABASE_URL="https://SEU_PROJETO.supabase.co"
SUPABASE_KEY="sua-service-role-key"
SUPABASE_BUCKET="product-images"

# Bootstrap — primeiro admin criado automaticamente se BD estiver vazio
# Mude estes valores ANTES do primeiro deploy
BOOTSTRAP_ADMIN_EMAIL="admin@sanflait.com"
BOOTSTRAP_ADMIN_PASSWORD="Admin@2026"
